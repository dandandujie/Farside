diff --git a/packages/agent-core-v2/src/agent/toolSelect/toolGroups.ts b/packages/agent-core-v2/src/agent/toolSelect/toolGroups.ts
new file mode 100644
index 0000000..0cf5f00
--- /dev/null
+++ b/packages/agent-core-v2/src/agent/toolSelect/toolGroups.ts
@@ -0,0 +1,77 @@
+/**
+ * Builtin tool groups used by Farside's progressive-disclosure policy.
+ *
+ * The default agent starts with six general-purpose coding tools. Less common
+ * capabilities stay active in the profile, but their schemas are loaded only
+ * when the model selects a group/name or the first user prompt contains a
+ * conservative, explicit intent signal.
+ */
+
+import type { ContextMessage } from '#/agent/contextMemory/types';
+
+export const CORE_BUILTIN_TOOL_NAMES = [
+  'Read',
+  'Write',
+  'Edit',
+  'Grep',
+  'Glob',
+  'Bash',
+] as const;
+
+export const BUILTIN_TOOL_GROUPS = {
+  planning: ['TodoList', 'EnterPlanMode', 'ExitPlanMode'],
+  goals: ['CreateGoal', 'GetGoal', 'SetGoalBudget', 'UpdateGoal'],
+  agents: ['Agent', 'AgentSwarm', 'TaskList', 'TaskOutput', 'TaskStop'],
+  automation: ['CronCreate', 'CronList', 'CronDelete'],
+  web: ['WebSearch', 'FetchURL'],
+  interaction: ['AskUserQuestion'],
+  skills: ['Skill'],
+  media: ['ReadMediaFile'],
+} as const;
+
+export type BuiltinToolGroup = keyof typeof BUILTIN_TOOL_GROUPS;
+
+const DEFERRED_BUILTIN_TOOL_NAMES = new Set<string>(
+  Object.values(BUILTIN_TOOL_GROUPS).flat(),
+);
+
+const CORE_BUILTIN_TOOL_NAME_SET = new Set<string>(CORE_BUILTIN_TOOL_NAMES);
+
+export function isDeferredBuiltinTool(name: string): boolean {
+  return name !== 'select_tools' && !CORE_BUILTIN_TOOL_NAME_SET.has(name);
+}
+
+export function expandBuiltinToolGroups(groups: readonly BuiltinToolGroup[]): string[] {
+  return [...new Set(groups.flatMap((group) => BUILTIN_TOOL_GROUPS[group]))]
+    .filter((name) => DEFERRED_BUILTIN_TOOL_NAMES.has(name));
+}
+
+export function inferBuiltinToolGroups(message: ContextMessage): BuiltinToolGroup[] {
+  if ((message.origin?.kind ?? 'user') !== 'user') return [];
+  const text = message.content
+    .filter((part): part is Extract<(typeof message.content)[number], { type: 'text' }> =>
+      part.type === 'text')
+    .map((part) => part.text)
+    .join('\n');
+  const groups: BuiltinToolGroup[] = [];
+
+  if (
+    /https?:\/\/|\b(?:web\s*search|search\s+the\s+web|fetch\s+(?:a\s+)?url|look\s+it\s+up)\b|联网|上网|搜索(?:网络|互联网)|查(?:找)?网页|最新(?:消息|新闻|版本|价格|文档)/iu.test(text)
+  ) groups.push('web');
+  if (
+    /\b(?:plan|planning|todo)\b|制定计划|先规划|任务清单|计划(?:一下|步骤|方案)/iu.test(text)
+  ) groups.push('planning');
+  if (
+    /\bgoals?\b|创建目标|设定目标|持续执行|不要停止|直到.+完成/iu.test(text)
+  ) groups.push('goals');
+  if (
+    /\b(?:sub-?agents?|agent\s*swarm|swarm)\b|子代理|子智能体|多代理|代理并行|并行.+(?:调查|研究|实现)/iu.test(text)
+  ) groups.push('agents');
+  if (
+    /\b(?:cron|scheduled?|remind(?:er|\s+me)?)\b|定时|提醒我|周期(?:执行|运行)|自动(?:执行|运行)/iu.test(text)
+  ) groups.push('automation');
+  if (/\bskills?\b|使用技能|加载技能/iu.test(text)) groups.push('skills');
+  if (message.content.some((part) => part.type !== 'text')) groups.push('media');
+
+  return groups;
+}
